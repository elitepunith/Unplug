<Window x:Class="UnplugReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unplug Reminder" Height="250" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Icon="appicon.ico">
    
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#3A3A3A" BorderThickness="1">
        
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⚡ Unplug Your Charger!" Foreground="#FFC107" 
                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,5"/>

            <TextBlock Grid.Row="1" Text="Leaving the laptop plugged in after shutdown can damage the battery over time. Please unplug the wire now." 
                       Foreground="#CCCCCC" FontSize="14" TextAlignment="Center" TextWrapping="Wrap" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0,20,0"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                
                <Button Content="Unplugged &amp; Shut Down" Width="170" Height="35" Margin="0,0,15,0"
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                        Click="Shutdown_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Cancel" Width="90" Height="35"
                        Background="#333333" Foreground="White" BorderThickness="0"
                        Click="Cancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>